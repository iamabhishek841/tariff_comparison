{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**": {
      "memory": 512,
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/(?!api)",
      "dest": "/"
    }
  ]
}

